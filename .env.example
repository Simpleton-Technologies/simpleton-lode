# Simpleton Technologies / Lode — development env example
# Copy to .env and fill in. For Vercel deploys, set these in
# Project → Settings → Environment Variables instead.

# ──────────────────────────────────────────────────────────────────────────
# Backend
# ──────────────────────────────────────────────────────────────────────────
PORT=3033

# ──────────────────────────────────────────────────────────────────────────
# Upstream market data (optional; falls back to mock prices)
# ──────────────────────────────────────────────────────────────────────────
KITCO_API_KEY=
METALS_API_KEY=
RAPAPORT_API_KEY=
CHRONO24_API_KEY=

# ──────────────────────────────────────────────────────────────────────────
# Founder pulse (nervous system auth)
# ──────────────────────────────────────────────────────────────────────────
# Long random string — protects /api/founder/pulse from public access.
# Generate one: openssl rand -hex 32
FOUNDER_KEY=

# ──────────────────────────────────────────────────────────────────────────
# Appraisal email send (SendGrid)  —  required for Lane 1 email delivery
# ──────────────────────────────────────────────────────────────────────────

# 1) API key with "Mail Send" permission:
# SendGrid → Settings → API Keys → Create API Key (Restricted Access, Mail Send only)
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxx

# 2) Verified sender. The address here must be authenticated in SendGrid,
#    either via Domain Authentication (covers the whole domain — preferred)
#    or Single Sender Verification (one specific address).
#
#    Accepted formats (either works):
#      APPRAISAL_FROM=appraisal@simpletontechnologies.com
#      APPRAISAL_FROM="Simpleton Technologies <appraisal@simpletontechnologies.com>"
APPRAISAL_FROM="Simpleton Technologies <appraisal@simpletontechnologies.com>"

# 3) Optional — reply-to on outbound appraisal emails.
APPRAISAL_REPLY_TO=appraisal@simpletontechnologies.com

# 4) Optional — BCC every send to your own inbox for the audit trail.
#    Useful until a persistent send log ships.
# APPRAISAL_BCC=intel@simpletonapp.com

# 5) Optional — override the "verify at" URL in the email body.
#    Defaults to https://simpletonapp.com/lookup
# VERIFY_BASE_URL=https://simpletonapp.com/lookup
